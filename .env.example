# ============================================================
# CONFIGURATION PRODUCTION - ESchool
# ============================================================
# Copiez ce fichier vers .env et remplissez les valeurs
# ============================================================

# ============================================================
# BASE DE DONNÉES
# ============================================================
POSTGRES_PASSWORD=VotreMotDePasseFort123!

# ============================================================
# OVH OBJECT STORAGE (S3)
# ============================================================
OVH_S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net/
OVH_S3_ACCESS_KEY=votre_access_key_ici
OVH_S3_SECRET_KEY=votre_secret_key_ici
OVH_S3_BUCKET=tan-chu
OVH_S3_REGION=gra

# ============================================================
# EMAIL (SMTP Gmail)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=henri@henrimorel.com
SMTP_PASS=votre_app_password

# ============================================================
# CLOUDFLARE (Optionnel - pour création auto DNS)
# ============================================================
CF_API_TOKEN=votre_token_cloudflare
CF_ZONE_ID=votre_zone_id
